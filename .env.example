# Expo Deployment Credentials
# Sign up at https://expo.io/signup
EXPO_CLI_USERNAME=your-expo-username
EXPO_CLI_PASSWORD=your-expo-password

# Codecov Token (optional, for coverage uploads)
# Get yours at https://codecov.io/gh/juninmd/aniversario-app
CODECOV_TOKEN=your-codecov-token

# Expo Packager Hostname (for development)
# Override the IP address for the React Native packager
REACT_NATIVE_PACKAGER_HOSTNAME=192.168.0.1
